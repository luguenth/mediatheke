ENVIRONMENT="prod"
POSTGRES_USER="username"
POSTGRES_PASSWORD="password"
POSTGRES_DB="default_database"
POSTGRES_PORT="5432"
POSTGRES_HOST="database"
SECRET_KEY="secret_key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="3600"
HOST_URL="mediatheke.develop"
URL_SCHEMA="https"
API_PATH="api"
#separate with comma if multiple mirrors are used
FILMLISTE_MIRRORS=verteiler1.mediathekview.de
OPENAI_KEY="xxx"
# OpenAI-compatible API (e.g. OpenRouter). Leave OPENAI_BASE_URL empty to use api.openai.com.
OPENAI_BASE_URL="https://openrouter.ai/api/v1"
OPENAI_MODEL="openai/gpt-oss-120b"
# Pin to a specific OpenRouter provider (e.g. "cerebras" for max speed).
# Leave empty to use OpenRouter's default routing.
OPENAI_PROVIDER="cerebras"
